# --- Database ---
DATABASE_URL=postgresql+psycopg://medbook:medbook@localhost:5432/medbook

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
ENCRYPTION_KEY=change-me-fernet-key-44-bytes-urlsafe-base64

# --- LLM providers ---
GEMINI_API_KEY=
OPENAI_API_KEY=
LLM_PRIMARY=gemini
LLM_FALLBACK=openai
# F26 cost guard: tokens/day summed across BOTH providers. At 80% we log a
# warning; at 100% agents are disabled (chat says "temporarily unavailable")
# while the manual booking flow keeps working. Set to 0 to disable the guard
# entirely — spend is still counted, nothing is ever blocked.
LLM_DAILY_TOKEN_BUDGET=200000

# --- Observability ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=medbook
SENTRY_DSN=
# The frontend's Sentry DSN lives in frontend/.env.local as
# NEXT_PUBLIC_SENTRY_DSN — Next.js only exposes NEXT_PUBLIC_*-prefixed vars
# to browser code, so a bare SENTRY_DSN_FRONTEND here would never reach it.
# See frontend/.env.example and docs/observability.md.

# --- Infra ---
CLOUDINARY_URL=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
SMS_GATEWAY_KEY=

# --- App ---
FRONTEND_ORIGIN=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO
